{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "rootDir": "src",
        "outDir": "dist-electron",
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "lib": ["ES2022", "DOM"],
        "types": ["node", "electron"]
    },
    "include": ["src/preload/**/*.ts", "src/shared/**/*.ts"]
}
